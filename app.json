{
  "expo": {
    "name": "Bebek Ses Çözücü",
    "slug": "bebek-ses-cozucu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bu uygulama bebek ağlama seslerini analiz etmek için mikrofon erişimi gerektirir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F3FF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "bebek-ses-cozucu",
    "plugins": [
      "expo-font"
    ],
    "jsEngine": "hermes",
    "experiments": {
      "turboModules": true
    }
  }
}
